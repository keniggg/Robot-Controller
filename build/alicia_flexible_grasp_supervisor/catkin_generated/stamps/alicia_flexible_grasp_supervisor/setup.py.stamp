#!/usr/bin/env python3
from distutils.core import setup
from catkin_pkg.python_setup import generate_distutils_setup

setup_args = generate_distutils_setup(
    packages=[
        'alicia_flexible_grasp',
        'alicia_flexible_grasp.tactile',
        'alicia_flexible_grasp.vision',
        'alicia_flexible_grasp.robot',
        'alicia_flexible_grasp.grasp',
        'alicia_flexible_grasp.utils',
    ],
    package_dir={'': 'src'},
)
setup(**setup_args)
