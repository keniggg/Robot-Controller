<launch>
    <arg name="namespace_prefix" default="d405_v4l2_charuco_handeyecalibration" />
    <arg name="device" default="/dev/video4" />
    <arg name="width" default="640" />
    <arg name="height" default="480" />
    <arg name="fps" default="30" />
    <arg name="camera_frame" default="camera_link" />
    <arg name="board_frame" default="charuco_board" />
    <arg name="camera_info_url" default="$(find alicia_d_calibration)/scripts/d405_factory_camera.yaml" />
    <arg name="start_rviz" default="false" />
    <arg name="start_image_view" default="true" />
    <arg name="image_view_topic" default="/charuco/result" />
    <arg name="start_sampling_gui" default="true" />
    <arg name="freehand_robot_movement" default="true" />

    <arg name="board_width" default="11" />
    <arg name="board_height" default="8" />
    <arg name="square_length" default="0.015" />
    <arg name="marker_length" default="0.011" />

    <node name="d405_v4l2_camera" pkg="alicia_d_calibration" type="d405_v4l2_camera.py" output="screen">
        <param name="device" value="$(arg device)" />
        <param name="width" value="$(arg width)" />
        <param name="height" value="$(arg height)" />
        <param name="fps" value="$(arg fps)" />
        <param name="frame_id" value="$(arg camera_frame)" />
        <param name="camera_info_url" value="$(arg camera_info_url)" />
    </node>

    <node name="charuco_tracker" pkg="alicia_d_calibration" type="charuco_tracker.py" output="screen">
        <param name="board_size" value="[$(arg board_width), $(arg board_height)]" />
        <param name="square_length" value="$(arg square_length)" />
        <param name="marker_length" value="$(arg marker_length)" />
        <param name="dictionary_id" value="DICT_4X4_100" />
        <param name="camera_frame" value="$(arg camera_frame)" />
        <param name="board_frame" value="$(arg board_frame)" />
        <param name="image_topic" value="/camera/color/image_raw" />
        <param name="camera_info_topic" value="/camera/color/camera_info" />
    </node>

    <include file="$(find easy_handeye)/launch/calibrate.launch">
        <arg name="namespace_prefix" value="$(arg namespace_prefix)" />
        <arg name="eye_on_hand" value="true" />
        <arg name="move_group" value="alicia" />
        <arg name="tracking_base_frame" value="$(arg camera_frame)" />
        <arg name="tracking_marker_frame" value="$(arg board_frame)" />
        <arg name="robot_base_frame" value="base_link" />
        <arg name="robot_effector_frame" value="tool0" />
        <arg name="freehand_robot_movement" value="$(arg freehand_robot_movement)" />
        <arg name="robot_velocity_scaling" value="0.3" />
        <arg name="robot_acceleration_scaling" value="0.2" />
        <arg name="translation_delta_meters" value="0.08" />
        <arg name="rotation_delta_degrees" value="18" />
        <arg name="start_rviz" value="$(arg start_rviz)" />
        <arg name="start_sampling_gui" value="$(arg start_sampling_gui)" />
    </include>

    <node if="$(arg start_image_view)" name="charuco_image_view" pkg="image_view" type="image_view" output="screen">
        <remap from="image" to="$(arg image_view_topic)" />
    </node>
</launch>
