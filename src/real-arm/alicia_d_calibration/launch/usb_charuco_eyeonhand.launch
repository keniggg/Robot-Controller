<launch>
    <arg name="namespace_prefix" default="charuco_handeyecalibration" />
    
    <!-- ChArUco board parameters -->
    <arg name="board_width" doc="Number of squares in width direction" default="11"/>
    <arg name="board_height" doc="Number of squares in height direction" default="8"/>
    <arg name="square_length" doc="Length of a square in meters" default="0.015"/>
    <arg name="marker_length" doc="Length of the markers in meters" default="0.011"/>
    
    <!-- ============================================================== -->
    <!-- ==                 启动机械臂的moveit控制                    == -->
    <!-- ============================================================== -->

    <include file="$(find alicia_d_driver)/launch/alicia_d_bringup.launch">
    </include>

    <!-- ============================================================== -->
    <!-- ==                 启动 Synria C10 USB Camera                     == -->
    <include file="$(find usb_cam)/launch/usb_cam-test.launch" />

    <!-- ============================================================== -->
    <!-- ==                    启动 ChArUco Tracker                  == -->
    <!-- ============================================================== -->
    <node name="charuco_tracker" pkg="alicia_d_calibration" type="charuco_tracker.py" output="screen">
        <param name="board_size" value="[$(arg board_width), $(arg board_height)]"/>
        <param name="square_length" value="$(arg square_length)"/>
        <param name="marker_length" value="$(arg marker_length)"/>
        <param name="dictionary_id" value="DICT_4X4_100"/>
        <param name="camera_frame" value="camera_link"/>
        <param name="board_frame" value="charuco_board"/>
    </node>

    <!-- ============================================================== -->
    <!-- ==                    启动 easy_handeye                     == -->
    <!-- ============================================================== -->
    <include file="$(find easy_handeye)/launch/calibrate.launch" >
        <arg name="namespace_prefix" value="$(arg namespace_prefix)" />
        <arg name="eye_on_hand" value="true" /> <!-- 确认是 Eye-in-Hand -->
        <arg name="move_group" value="alicia" />

        <!-- 相机基础坐标系 (TF由此发布) -->
        <arg name="tracking_base_frame" value="camera_link" />
        
        <!-- 检测到的ChArUco板坐标系 (由 ChArUco tracker 发布，相对于 tracking_base_frame) -->
        <arg name="tracking_marker_frame" value="charuco_board" />
        
        <!-- 机器人基坐标系 -->
        <arg name="robot_base_frame" value="base_link" />
        
        <!-- **标记附着**在哪个连杆上 (非常重要!) -->
        <arg name="robot_effector_frame" value="tool0" />

        <arg name="freehand_robot_movement" value="false" />
        <arg name="robot_velocity_scaling" value="0.5" />
        <arg name="robot_acceleration_scaling" value="0.2" />
        
        <!-- ChArUco specific parameters -->
        <arg name="translation_delta_meters" value="0.15" />
        <arg name="rotation_delta_degrees" value="25" />
    </include>

    <!-- ============================================================== -->
    <!-- ==                    启动 RViz 可视化                      == -->
    <!-- ============================================================== -->
    <!-- <node name="rviz" pkg="rviz" type="rviz" args="-d $(find alicia_d_calibration)/launch/charuco_calibration.rviz" /> -->

</launch>
