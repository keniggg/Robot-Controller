<launch>
  <!--
  ===================================================================================
  |      Main Bringup Launch File for the Alicia-D Robot with MoveIt!              |
  ===================================================================================
  -->
  <arg name="moveit_controller_manager" default="simple"/>
  <arg name="port" default="/dev/alicia_arm" />
  <arg name="baudrate" default="1000000" />
  <arg name="start_rviz" default="false" />
  <arg name="ros_control_publish_only_on_change" default="true" />
  <arg name="ros_control_publish_gripper_command" default="false" />
  <arg name="auto_torque_on_startup" default="false" />
  <!-- Load the URDF, SRDF and other .yaml configuration files on the param server -->
  <include file="$(find alicia_d_moveit)/launch/planning_context.launch">
    <arg name="load_robot_description" value="true"/>
  </include>

  <!-- Load the ROS controllers configuration -->
  <rosparam file="$(find alicia_d_driver)/config/controllers.yaml" command="load" />
  
  <!-- Load the MoveIt controller connection file -->
  <rosparam file="$(find alicia_d_moveit)/config/simple_moveit_controllers.yaml"/>

  <!-- =================================================================================== -->
  <!-- |                       START THE HARDWARE AND ROS_CONTROL                          | -->
  <!-- =================================================================================== -->

  <node name="alicia_d_driver_node" pkg="alicia_d_driver" type="alicia_d_driver_node" output="screen">
    
      <!-- Serial Port Configuration -->
      <param name="port"           type="string" value="$(arg port)"/>
      <param name="baud_rate"      type="int"    value="$(arg baudrate)"/>
      <param name="baudrate"       type="int"    value="$(arg baudrate)"/>
      
      <!-- Driver Behavior Configuration -->
      <param name="debug_mode"     type="bool"   value="false"/>
      <param name="auto_torque_on_startup" type="bool" value="$(arg auto_torque_on_startup)"/>
      <param name="rate_limit_sec" type="double" value="0.01"/>
        <!-- Command streaming and smoothing -->
        <param name="command_rate_hz"           type="double" value="50.0"/>
        <param name="state_poll_rate_hz"        type="double" value="10.0"/>
        <param name="temperature_poll_rate_hz"  type="double" value="1.0"/>
        <param name="self_check_poll_rate_hz"   type="double" value="0.5"/>
        <param name="mirror_commanded_state_when_feedback_stale" type="bool" value="false"/>
        <param name="log_command_flow"          type="bool"   value="true"/>
        <param name="suppress_redundant_commands" type="bool" value="true"/>
        <param name="pause_commands_when_feedback_stale" type="bool" value="true"/>
        <param name="feedback_stale_timeout_sec" type="double" value="1.0"/>
        <param name="protection_clear_stable_sec" type="double" value="30.0"/>
        <param name="max_enable_temperature_c" type="double" value="60.0"/>
        <param name="e1_confirm_consecutive_frames" type="int" value="3"/>
        <param name="temperature_over_limit_confirm_samples" type="int" value="3"/>
        <param name="command_keepalive_rate_hz" type="double" value="0.0"/>
        <!-- joint_trajectory_controller already interpolates MoveIt paths. A
             second driver-side profile makes hardware lag behind action success. -->
        <param name="use_trajectory_smoothing"  type="bool"   value="false"/>
        <param name="max_joint_velocity_rad_s"  type="double" value="0.30"/>
        <param name="max_joint_accel_rad_s2"    type="double" value="1.0"/>
        <param name="joint_speed_deg_s"         type="double" value="15.0"/>
        <param name="max_gripper_velocity_rad_s" type="double" value="2.0"/>
        <param name="max_gripper_accel_rad_s2"   type="double" value="15.0"/>
        <param name="gripper_input_is_percent"  type="bool"   value="false"/>
        <!-- Stroke length of prismatic gripper joint (meters). Used for unit conversion. -->
        <param name="gripper_stroke_m"          type="double" value="0.05"/>
  </node>



  <!-- Load the joint names for the hardware interface -->
  <rosparam file="$(find alicia_d_driver)/config/joint_names.yaml" command="load" />
  
  <!-- Start the ros_control hardware interface node -->
  <node name="bessica_d_hw_interface" pkg="alicia_d_driver" type="alicia_d_hw_interface_node" output="screen">
    <param name="publish_only_on_change" type="bool" value="$(arg ros_control_publish_only_on_change)"/>
    <param name="publish_initial_command" type="bool" value="false"/>
    <param name="command_publish_epsilon" type="double" value="0.00001"/>
    <param name="publish_gripper_command" type="bool" value="$(arg ros_control_publish_gripper_command)"/>
    <param name="gripper_joint_name" type="string" value="right_finger"/>
  </node>

  <!-- Load the robot state publisher. No remapping needed now. -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" respawn="true" output="screen" />
  
  <!-- Load the controller spawner in the global namespace -->
  <!-- Only spawn trajectory controllers. The driver already publishes /joint_states. -->
  <node name="controller_spawner" pkg="controller_manager" type="spawner" respawn="false"
    output="screen" args="
      alicia_controller
      hand_controller
    "/>

  <!-- =================================================================================== -->
  <!-- |                                  START MOVEIT!                                  | -->
  <!-- =================================================================================== -->
  
  <!-- Run the main MoveIt! planning execution context -->
  <include file="$(find alicia_d_moveit)/launch/move_group.launch">
    <arg name="load_robot_description" value="false"/>
    <arg name="moveit_controller_manager" value="$(arg moveit_controller_manager)" />
  </include>

  <!-- =================================================================================== -->
  <!-- |                                 START VISUALIZATION                             | -->
  <!-- =================================================================================== -->

  <!-- RViz is optional. The supervisor GUI owns normal manual control/planning. -->
  <include if="$(arg start_rviz)" file="$(find alicia_d_moveit)/launch/moveit_rviz.launch">
    <arg name="rviz_config" value="$(find alicia_d_moveit)/launch/moveit.rviz"/>
  </include>

</launch>
