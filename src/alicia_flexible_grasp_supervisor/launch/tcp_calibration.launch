<launch>
  <arg name="start_motion_gateway" default="true" />
  <arg name="start_gui" default="true" />

  <rosparam command="load" file="$(find alicia_flexible_grasp_supervisor)/config/joint_limits.yaml" />
  <rosparam command="load" file="$(find alicia_flexible_grasp_supervisor)/config/grasp_params.yaml" />
  <rosparam command="load" file="$(find alicia_flexible_grasp_supervisor)/config/handeye.yaml" />
  <rosparam command="load" file="$(find alicia_flexible_grasp_supervisor)/config/gui_config.yaml" />
  <rosparam command="load" file="$(find alicia_flexible_grasp_supervisor)/config/tcp_calibration.yaml" />

  <node if="$(arg start_motion_gateway)" pkg="alicia_flexible_grasp_supervisor"
        type="motion_gateway_node.py" name="motion_gateway" output="screen" />
  <node pkg="alicia_flexible_grasp_supervisor" type="tcp_calibration_node.py"
        name="tcp_calibration" output="screen" />
  <node if="$(arg start_gui)" pkg="alicia_flexible_grasp_supervisor"
        type="main_gui.py" name="alicia_supervisor_gui" output="screen" />
</launch>
